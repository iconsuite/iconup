{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "iCONup",
  "version": "1.0.135",
  "identifier": "it.iconsuite.iconup",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
          {
            "title": "iCONup - iCON Suite Installer",
            "width": 600,
            "height": 770,
            "minWidth": 500,
            "minHeight": 600,
            "resizable": false,
            "center": true,
            "hiddenTitle": true,
            "titleBarStyle": "Overlay",
            "trafficLightPosition": { "x": 7, "y": 3 }
          }
        ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "Entitlements.plist",
      "signingIdentity": "-"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
